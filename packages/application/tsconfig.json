{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@balanceframe/actual-adapter": ["../actual-adapter/src"],
      "@balanceframe/actual-adapter/*": ["../actual-adapter/src/*"],
      "@balanceframe/workflow-store": ["../workflow-store/src"],
      "@balanceframe/workflow-store/*": ["../workflow-store/src/*"],
      "@balanceframe/protocol-generated": ["../protocol-generated/src"],
      "@balanceframe/protocol-generated/*": ["../protocol-generated/src/*"]
    }
  },
  "include": ["src"]
}
