{
  "name": "@balanceframe/protocol-generated",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Generated TS types from JSON Schema with runtime Zod validators",
  "main": "src/index.ts",
  "types": "src/index.ts",
