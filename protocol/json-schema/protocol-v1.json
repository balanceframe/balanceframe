{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://balanceframe.dev/schemas/protocol-v1.json",
  "title": "BalanceFrame Protocol v1",
  "description": "Rust-owned normalized protocol. JSON uses camelCase, matching serde(rename_all = \"camelCase\").",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "actualVersion",
    "snapshotDate",
    "accounts",
    "transactions",
    "categories",
    "payees",
    "rules",
    "schedules",
    "budgets",
    "tags"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1"
    },
    "actualVersion": {
      "type": "string"
    },
    "snapshotDate": {
      "type": "string"
    },
    "accounts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Account"
      }
    },
    "transactions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Transaction"
      }
    },
    "categories": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Category"
      }
    },
    "payees": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Payee"
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Rule"
      }
    },
    "schedules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Schedule"
      }
    },
    "budgets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/BudgetMonth"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Tag"
      }
    }
  },
  "$defs": {
    "Money": {
      "type": "object",
      "required": [
        "minorUnits",
        "currency"
      ],
      "additionalProperties": false,
      "properties": {
        "minorUnits": {
          "type": "string",
          "pattern": "^-?\\d+$"
        },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        }
      }
    },
    "Account": {
      "type": "object",
      "required": [
        "id",
        "name",
        "accountType",
        "offBudget",
        "isClosed",
        "clearedBalance",
        "importedBalance",
        "mtid"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "accountType": {
          "enum": [
            "checking",
            "savings",
            "creditCard",
            "cash",
            "investment",
            "mortgage",
            "loan",
            "other"
          ]
        },
        "offBudget": {
          "type": "boolean"
        },
        "isClosed": {
          "type": "boolean"
        },
        "clearedBalance": {
          "$ref": "#/$defs/Money"
        },
        "importedBalance": {
          "$ref": "#/$defs/Money"
        },
        "mtid": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "Transaction": {
      "type": "object",
      "required": [
        "id",
        "accountId",
        "date",
        "payeeId",
        "payeeName",
        "categoryId",
        "categoryName",
        "amount",
        "cleared",
        "reconciled",
        "importedId",
        "importedPayee",
        "notes",
        "tags",
        "transferAccountId",
        "subtransactions"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string"
        },
        "accountId": {
          "type": "string"
        },
        "date": {
          "type": "string"
        },
        "payeeId": {
          "type": [
            "string",
            "null"
          ]
        },
        "payeeName": {
          "type": [
            "string",
            "null"
          ]
        },
        "categoryId": {
          "type": [
            "string",
            "null"
          ]
        },
        "categoryName": {
          "type": [
            "string",
            "null"
          ]
        },
        "amount": {
          "$ref": "#/$defs/Money"
        },
        "cleared": {
          "type": "boolean"
        },
        "reconciled": {
          "type": "boolean"
        },
        "importedId": {
          "type": [
            "string",
            "null"
          ]
        },
        "importedPayee": {
          "type": [
            "string",
            "null"
          ]
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "transferAccountId": {
          "type": [
            "string",
            "null"
          ]
        },
        "subtransactions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Transaction"
          }
        }
      }
    },
    "Category": {
      "type": "object",
      "required": [
        "id",
        "name",
        "groupName",
        "isIncome",
        "mtid",
        "deleted"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "groupName": {
          "type": [
            "string",
            "null"
          ]
        },
        "isIncome": {
          "type": "boolean"
        },
        "mtid": {
          "type": [
            "string",
            "null"
          ]
        },
        "deleted": {
          "type": "boolean"
        }
      }
    },
    "Payee": {
      "type": "object",
      "required": [
        "id",
        "name",
        "transferAccountId",
        "mtid"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "transferAccountId": {
          "type": [
            "string",
            "null"
          ]
        },
        "mtid": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "Rule": {
      "type": "object",
      "required": [
        "id",
        "name",
        "order",
        "trigger",
        "actions",
        "inactive"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "order": {
          "type": "integer",
          "minimum": 0
        },
        "trigger": {},
        "actions": {},
        "inactive": {
          "type": "boolean"
        }
      }
    },
    "Schedule": {
      "type": "object",
      "required": [
        "id",
        "frequency",
        "amount",
        "payeeName",
        "accountId",
        "nextExpected"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string"
        },
        "frequency": {
          "type": "string"
        },
        "amount": {
          "$ref": "#/$defs/Money"
        },
        "payeeName": {
          "type": [
            "string",
            "null"
          ]
        },
        "accountId": {
          "type": "string"
        },
        "nextExpected": {
          "type": "string"
        }
      }
    },
    "BudgetCategory": {
      "type": "object",
      "required": [
        "categoryId",
        "amount",
        "carryover",
        "carryoverFromPrevious",
        "carriesOver"
      ],
      "additionalProperties": true,
      "properties": {
        "categoryId": {
          "type": "string"
        },
        "amount": {
          "$ref": "#/$defs/Money"
        },
        "carryover": {
          "$ref": "#/$defs/Money"
        },
        "carryoverFromPrevious": {
          "$ref": "#/$defs/Money"
        },
        "carriesOver": {
          "type": "boolean"
        }
      }
    },
    "BudgetMonth": {
      "type": "object",
      "required": [
        "id",
        "month",
        "categories"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string"
        },
        "month": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}$"
        },
        "categories": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/BudgetCategory"
          }
        }
      }
    },
    "Tag": {
      "type": "object",
      "required": [
        "id",
        "name"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      }
      },
    "Provenance": {
      "type": "object",
      "required": [
        "payloadHash",
        "createdAt"
      ],
      "additionalProperties": false,
      "properties": {
        "payloadHash": {
          "type": "string"
        },
        "provider": {
          "type": ["string", "null"]
        },
        "model": {
          "type": ["string", "null"]
        },
        "promptVersion": {
          "type": ["string", "null"]
        },
        "inferencePolicyVersion": {
          "type": ["string", "null"]
        },
        "createdAt": {
          "type": "string"
        },
        "actorId": {
          "type": ["string", "null"]
        }
      }
    },
    "HistoryRecord": {
      "type": "object",
      "required": [
        "transactionId",
        "payeeName",
        "categoryId",
        "categoryName",
        "amount",
        "date"
      ],
      "additionalProperties": false,
      "properties": {
        "transactionId": {
          "type": "string"
        },
        "payeeName": {
          "type": "string"
        },
        "categoryId": {
          "type": "string"
        },
        "categoryName": {
          "type": "string"
        },
        "amount": {
          "$ref": "#/$defs/Money"
        },
        "date": {
          "type": "string"
        }
      }
    },
    "Suggestion": {
      "type": "object",
      "required": [
        "transactionId",
        "proposedCategoryId",
        "categoryName",
        "confidence",
        "reasonCodes",
        "evidence"
      ],
      "additionalProperties": false,
      "properties": {
        "transactionId": {
          "type": "string"
        },
        "proposedCategoryId": {
          "type": "string"
        },
        "categoryName": {
          "type": "string"
        },
        "confidence": {
          "type": "number"
        },
        "reasonCodes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "spaceId": {
          "type": ["string", "null"]
        },
        "connectionId": {
          "type": ["string", "null"]
        },
        "budgetId": {
          "type": ["string", "null"]
        },
        "transactionVersion": {
          "type": ["string", "null"]
        },
        "rawMerchant": {
          "type": ["string", "null"]
        },
        "normalizedMerchant": {
          "type": ["string", "null"]
        },
        "researchSummary": {
          "type": ["string", "null"]
        },
        "alternativeCategoryIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rationale": {
          "type": ["string", "null"]
        },
        "provider": {
          "type": ["string", "null"]
        },
        "model": {
          "type": ["string", "null"]
        },
        "promptVersion": {
          "type": ["string", "null"]
        },
        "inferencePolicyVersion": {
          "type": ["string", "null"]
        },
        "createdAt": {
          "type": ["string", "null"]
        },
        "actorId": {
          "type": ["string", "null"]
        },
        "payloadHash": {
          "type": ["string", "null"]
        },
        "provenance": {
          "anyOf": [
            {"$ref": "#/$defs/Provenance"},
            {"type": "null"}
          ]
        },
        "history": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/HistoryRecord"
          }
        },
        "id": {
          "type": "string"
        },
        "alternatives": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["categoryId", "reason"],
            "additionalProperties": false,
            "properties": {
              "categoryId": { "type": "string" },
              "reason": { "type": "string" }
            }
          }
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "deterministicEvidence": {
          "type": "object",
          "additionalProperties": {}
        }
      }
    }
  }
}
