{
  "name": "balanceframe",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "description": "Monorepo for BalanceFrame — financial categorization using Actual Budget",
  "workspaces": [
    "packages/*",
    "apps/*",
    "tests/*",
    "crates/*"
  ],
  "engines": {
    "node": ">=20",
    "pnpm": "10.x"
  },
  "packageManager": "pnpm@10.24.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  }
}
